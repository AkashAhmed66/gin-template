# =============================================================================
# Application
# =============================================================================
APP_NAME=gin-template
APP_ENV=dev                       # dev | prod
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=30s

# =============================================================================
# Database
# =============================================================================
# driver: postgres | mysql
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gin_template
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_POOL_MAX_OPEN=20
DB_POOL_MAX_IDLE=5
DB_POOL_CONN_MAX_LIFETIME=1h

# =============================================================================
# Migrations (goose)
# =============================================================================
MIGRATIONS_DIR=migrations
MIGRATIONS_AUTO_RUN=true

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=debug                   # debug | info | warn | error
LOG_FORMAT=console                # console | json
LOG_DIR=logs

# =============================================================================
# JWT
# =============================================================================
# base64-encoded 256-bit (32-byte) secret. ALWAYS override in prod.
JWT_SECRET=Y2hhbmdlLW1lLWluLXByb2QtdGhpcy1pcy1ub3Qtc2VjdXJlLXNlY3JldC1rZXk=
JWT_ISSUER=gin-template
JWT_ACCESS_TTL=60m
JWT_REFRESH_TTL=336h              # 14d

# =============================================================================
# Sessions
# =============================================================================
SESSIONS_CLEANUP_INTERVAL=1h
SESSIONS_CLEANUP_RETENTION=168h   # 7d

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_EXPOSED_HEADERS=Authorization,X-Request-Id,X-RateLimit-Limit,X-RateLimit-Remaining,Retry-After
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# =============================================================================
# Rate limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_REFILL_TOKENS=60
RATE_LIMIT_REFILL_PERIOD=1m
RATE_LIMIT_AUTH_CAPACITY=10
RATE_LIMIT_AUTH_REFILL_TOKENS=10
RATE_LIMIT_AUTH_REFILL_PERIOD=1m

# =============================================================================
# Idempotency
# =============================================================================
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_TTL=24h
IDEMPOTENCY_CLEANUP_INTERVAL=1h

# =============================================================================
# Audit logging
# =============================================================================
AUDIT_ENABLED=true
AUDIT_EXPOSE_API=true
AUDIT_AUDIT_ALL=true
AUDIT_CAPTURE_REQUEST_BODY=true
AUDIT_CAPTURE_RESPONSE_BODY=true
AUDIT_MAX_BODY_LENGTH=10000

# =============================================================================
# File storage
# =============================================================================
STORAGE_BASE_PATH=uploads
STORAGE_MAX_UPLOAD_SIZE=10485760  # 10 MB

# =============================================================================
# Mail (SMTP)
# =============================================================================
# Master switch. Off by default so misconfigured local runs don't silently swallow mail.
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_TLS=true                     # STARTTLS
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Gin Template
MAIL_APP_URL=http://localhost:8080
MAIL_PASSWORD_RESET_TTL=30m
MAIL_PASSWORD_RESET_CLEANUP_INTERVAL=1h

# =============================================================================
# Bootstrap admin (DataInitializer creates on first boot if missing)
# =============================================================================
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=admin123
