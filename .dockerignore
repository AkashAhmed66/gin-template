# Source control
.git
.gitignore
.gitattributes
.github

# IDE / editor
.idea
.vscode
*.swp

# Build outputs
bin/
dist/
*.exe
*.test
*.out

# Runtime data — do NOT bake into the image
logs/
uploads/
tmp/

# Local env / secrets — never copy into images
.env
.env.local
.env.*.local

# Swagger spec is regenerated by `swag init` during the build
docs/

# Docker meta
Dockerfile
docker-compose*.yml
.dockerignore

# Tooling that doesn't belong in the image
Makefile
.air.toml
*.md
LICENSE

# OS junk
.DS_Store
Thumbs.db
